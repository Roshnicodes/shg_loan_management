<% content_for :title, "Login - Cash 360" %>

<section class="login-page">
  <div class="login-card">
    <div class="login-story">
      <div class="hero-photo">
        <%= image_tag "wash-community-finance.jpeg", alt: "Community members receiving WASH support material" %>
        <div class="login-photo-badge">
          <strong>WASH Finance</strong>
          <span>Community first, field ready</span>
        </div>
      </div>
      <div class="login-story-copy">
        <%= image_tag "asa-logo.png", alt: "ASA Action for Social Advancement", class: "asa-login-logo" %>
        <h1>Enabling WASH Access Through Community Finance</h1>
        <p>A digital platform supporting ASA's Water, Sanitation and Hygiene financing initiatives with field tracking, loan monitoring and repayment management.</p>
        <div class="login-story-tags">
          <span>Water</span>
          <span>Sanitation</span>
          <span>Hygiene</span>
          <span>Finance</span>
        </div>
      </div>
    </div>

    <div class="login-panel">
      <div class="login-panel-inner">
        <div class="login-panel-kicker">Secure Access</div>
        <%= image_tag "cash360-logo.png", alt: "Cash 360", class: "login-logo" %>
        <h2>Welcome Back!</h2>
        <p>Please sign in to continue.</p>
        <%= form_with url: login_path, class: "login-form" do |form| %>
          <label>
            <span>Login ID</span>
            <%= form.text_field :login_id, value: @remembered_login_id, placeholder: "Enter your login ID", required: true, autofocus: true, autocomplete: "username" %>
          </label>
          <label>
            <span>Password</span>
            <%= form.password_field :password, placeholder: "Enter your password", required: true, autocomplete: "current-password" %>
          </label>
          <label class="checkbox-field"><span>Keep me logged in</span><%= form.check_box :keep_login %></label>
          <%= form.submit "Sign In", class: "primary-button login-submit" %>
        <% end %>
        <div class="login-security-note">
          <strong>Authorized access only</strong>
          <span>Use the official account credentials assigned by the admin team.</span>
        </div>
      </div>
    </div>

    <div class="login-benefits">
      <span class="benefit-wash"><b>WASH Financing</b><small>Supporting access to water, sanitation and hygiene solutions</small></span>
      <span class="benefit-loan"><b>Loan Tracking</b><small>Monitor applications, approvals and repayments</small></span>
      <span class="benefit-field"><b>Field Mapping</b><small>Track households, villages and field-level progress</small></span>
      <span class="benefit-secure"><b>Secure & Reliable</b><small>Data is protected and access-controlled</small></span>
    </div>
  </div>
</section>
