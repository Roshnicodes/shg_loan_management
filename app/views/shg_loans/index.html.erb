<% content_for :page_title, "SHG Loans" %>

<section class="panel">
  <div class="panel-header">
    <div><p class="eyebrow">Loans</p><h2>SHG Loan Forms</h2></div>
    <div class="action-row">
      <%= link_to "Export CSV", export_shg_loans_path(request.query_parameters), class: "secondary-link" %>
      <% if can_bulk_delete_records? %>
        <%= form_with url: bulk_disable_shg_loans_path(request.query_parameters), method: :patch, id: "bulk-disable-loans" do |form| %>
          <%= form.submit "Disable Selected", class: "warning-link", data: { turbo_confirm: "Disable selected loans?" } %>
        <% end %>
      <% end %>
      <% if can_create_records? %><%= link_to "Add Loan", new_shg_loan_path, class: "primary-link" %><% end %>
      <%= server_search_box(shg_loans_path, placeholder: "Search loans...") %>
    </div>
  </div>

  <% if can_import_loan_data? %>
    <div class="inline-import-panel">
      <%= form_with url: import_shg_loans_path, multipart: true, class: "inline-import-form" do |form| %>
        <label>
          <span>Import Loan Excel/CSV</span>
          <%= form.file_field :file, accept: ".csv,text/csv,.xlsx,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", required: true %>
        </label>
        <%= form.submit "Upload Loan Data", class: "primary-button" %>
      <% end %>
    </div>

  <% end %>

  <%= form_with url: shg_loans_path, method: :get, class: "filter-grid", data: { controller: "location-select" } do |form| %>
    <%= form.hidden_field :q, value: params[:q] if params[:q].present? %>
    <label><span>From Date</span><%= form.date_field :date_from, value: params[:date_from] %></label>
    <label><span>To Date</span><%= form.date_field :date_to, value: params[:date_to] %></label>
    <% if can_filter_loan_state_district_crp? %>
      <label><span>State</span><%= form.collection_select :state_id, @states, :id, :name, { prompt: "All states", selected: params[:state_id] }, data: { location_select_target: "state", action: "location-select#stateChanged" } %></label>
      <label><span>District</span><%= form.select :district_id, options_for_select(district_filter_options(@districts), params[:district_id]), { prompt: "All districts" }, data: { location_select_target: "district", action: "location-select#districtChanged" } %></label>
    <% end %>
    <label><span>Block</span><%= form.select :block_id, options_for_select(block_filter_options(@blocks), params[:block_id]), { prompt: "All blocks" }, data: { location_select_target: "block", action: "location-select#blockChanged" } %></label>
    <label><span>Village</span><%= form.select :village_id, options_for_select(village_filter_options(@villages), params[:village_id]), { prompt: "All villages" }, data: { location_select_target: "village" } %></label>
    <label><span>SHG</span><%= form.collection_select :shg_id, @shgs, :id, :name, { prompt: "All SHG", selected: params[:shg_id] } %></label>
    <% if can_filter_loan_state_district_crp? %>
      <label><span>CRP</span><%= form.select :crp_id, options_for_select(user_filter_options(@crps), params[:crp_id]), { prompt: "All CRP" }, data: { location_select_target: "crp" } %></label>
    <% end %>
    <div class="filter-actions">
      <%= link_to "Clear", shg_loans_path, class: "secondary-link" %>
      <%= form.submit "Apply", class: "primary-button" %>
    </div>
  <% end %>

  <div class="form-help full">
    Download will follow the selected date, location and CRP filters.
  </div>

  <div class="searchable-table compact-search-results">
    <% if @loans.blank? %><div class="table-empty-state">No matching loans found.</div><% end %>
    <div class="table-wrap">
    <table class="loan-import-table">
      <thead>
        <tr>
          <% if can_bulk_delete_records? %><th class="select-column"><%= check_box_tag "select_all_loans", "1", false, data: { bulk_select_all: true, bulk_select_form: "bulk-disable-loans" }, aria: { label: "Select all loans on this page" } %></th><% end %>
          <th>SHG</th>
          <th>Member</th>
          <th>State</th>
          <th>District</th>
          <th>Block</th>
          <th>Village</th>
          <th>CRP ID</th>
          <th>CRPName</th>
          <th>Product</th>
          <th>Disbursement Date</th>
          <th>Loan Status</th>
          <th>Record</th>
          <th>Term Type</th>
          <th>Loan term</th>
          <th>Principal</th>
          <th>Annual Interest Percent</th>
          <th>Interest Amount</th>
          <th>Total Payable</th>
          <th>Principal Collected</th>
          <th>Interest collected</th>
          <th>Paid</th>
          <th>Remaining</th>
          <th>Mobile</th>
          <th>Monthly hh income</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% @loans.each do |loan| %>
          <tr>
            <% if can_bulk_delete_records? %><td><%= check_box_tag "ids[]", loan.id, false, form: "bulk-disable-loans", disabled: !loan.active? %></td><% end %>
            <td><%= loan.shg.name %></td>
            <td><%= link_to loan.shg_member.name, loan %></td>
            <td><%= loan.shg.state.name %></td>
            <td><%= loan.shg.district.name %></td>
            <td><%= loan.shg.block.name %></td>
            <td><%= loan.shg.village.name %></td>
            <td><%= loan_crp_identifier(loan).presence || "-" %></td>
            <td><%= loan_crp_name(loan).presence || "-" %></td>
            <td><%= loan.product.name %></td>
            <td><%= formatted_import_date(loan.distribution_date) %></td>
            <td><span class="status"><%= loan_status_label(loan) %></span></td>
            <td><span class="status <%= loan.active? ? "approved" : "rejected" %>"><%= loan.active? ? "Active" : "Inactive" %></span></td>
            <td><%= loan.loan_term_type %></td>
            <td><%= loan.loan_term %></td>
            <td><%= number_to_currency(loan.principal_amount, unit: "₹") %></td>
            <td><%= loan.interest_percent.present? ? loan.interest_percent : "-" %></td>
            <td><%= number_to_currency(loan_interest_amount(loan), unit: "₹") %></td>
            <td><%= number_to_currency(loan_total_payable(loan), unit: "₹") %></td>
            <td><%= number_to_currency(loan_principal_collect(loan), unit: "₹") %></td>
            <td><%= number_to_currency(loan_interest_collect(loan), unit: "₹") %></td>
            <td><%= number_to_currency(loan_paid_amount(loan), unit: "₹") %></td>
            <td><%= number_to_currency(loan_remaining_amount(loan), unit: "₹") %></td>
            <td><%= loan.shg_member.mobile.presence || "-" %></td>
            <td><%= loan.shg_member.monthly_income.present? ? number_to_currency(loan.shg_member.monthly_income, unit: "₹") : "-" %></td>
            <td><div class="action-row"><%= link_to "Details", loan %><%= link_to "Passbook", passbook_shg_loan_path(loan) %><% if can_manage_records? %><%= link_to "Edit", edit_shg_loan_path(loan) %><% end %><% if can_bulk_delete_records? && loan.active? %><%= button_to "Disable", disable_shg_loan_path(loan), method: :patch, class: "warning-link", form: { data: { turbo_confirm: "Disable this loan?" } } %><% elsif !loan.active? %><span class="muted-cell">Disabled</span><% end %></div></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    </div>
  </div>
  <%= pagination_controls("loans") %>
</section>
