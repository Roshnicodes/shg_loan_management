<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Cash 360" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Cash 360">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if logged_in? %>
      <div class="app-shell">
        <header class="mobile-appbar">
          <button type="button" class="mobile-menu-button" data-mobile-menu-toggle aria-label="Open menu" aria-controls="mobile-menu-drawer" aria-expanded="false">
            <span></span>
            <span></span>
            <span></span>
          </button>
          <%= image_tag "cash360-logo.png", alt: "Cash 360", class: "mobile-app-logo" %>
          <div class="mobile-app-title">
            <% if content_for?(:page_title) %>
              <strong><%= content_for(:page_title) %></strong>
            <% else %>
              <strong>Cash 360</strong>
            <% end %>
            <span><%= current_user.name %></span>
          </div>
        </header>
        <aside class="sidebar">
          <div class="brand">
            <%= image_tag "cash360-logo.png", alt: "Cash 360", class: "brand-logo" %>
          </div>
          <nav>
            <% app_nav_items.each do |label, path| %>
              <%= link_to label, path, class: ("active" if request.path == path) %>
            <% end %>
          </nav>
        </aside>
        <main class="main">
          <header class="topbar">
            <div>
              <p class="eyebrow">Welcome</p>
              <% if content_for?(:page_title) %>
                <h1><%= content_for(:page_title) %></h1>
              <% else %>
                <%= image_tag "cash360-logo.png", alt: "Cash 360", class: "topbar-logo" %>
              <% end %>
            </div>
            <div class="user-pill">
              <%= link_to current_user.name, profile_path, class: "user-profile-link" %>
              <%= button_to "Logout", logout_path, method: :delete, class: "link-button" %>
            </div>
          </header>
          <%= render "shared/flash" %>
          <%= yield %>
        </main>
        <div class="mobile-menu-backdrop" data-mobile-menu-close></div>
        <aside class="mobile-menu-drawer" id="mobile-menu-drawer" aria-hidden="true">
          <div class="mobile-menu-head">
            <%= image_tag "cash360-logo.png", alt: "Cash 360", class: "mobile-menu-logo" %>
            <button type="button" class="mobile-menu-close" data-mobile-menu-close aria-label="Close menu">Close</button>
          </div>
          <div class="mobile-menu-user">
            <strong><%= current_user.name %></strong>
            <span><%= current_user.user_type&.name.presence || current_user.designation %></span>
          </div>
          <nav class="mobile-menu-nav">
            <% app_nav_items.each do |label, path| %>
              <%= link_to path, class: ("active" if request.path == path) do %>
                <span></span>
                <strong><%= label %></strong>
              <% end %>
            <% end %>
          </nav>
          <%= button_to "Logout", logout_path, method: :delete, class: "mobile-menu-logout" %>
        </aside>
      </div>
    <% else %>
      <%= render "shared/flash" %>
      <%= yield %>
    <% end %>
  </body>
</html>
