<% content_for :page_title, "SHG Members" %>

<section class="panel">
  <div class="panel-header">
    <div><p class="eyebrow">Members</p><h2>SHG Members</h2></div>
    <div class="action-row">
      <%= link_to "Download CSV", export_shg_members_path(request.query_parameters), class: "secondary-link" %>
      <% if can_bulk_delete_records? %>
        <%= form_with url: bulk_disable_shg_members_path(request.query_parameters), method: :patch, id: "bulk-disable-members" do |form| %>
          <%= form.submit "Disable Selected", class: "warning-link", data: { turbo_confirm: "Disable selected members?" } %>
        <% end %>
      <% end %>
      <% if can_create_records? && visible_shgs.exists? %><%= link_to "Add Member", new_shg_member_path, class: "primary-link" %><% end %>
      <%= server_search_box(shg_members_path, placeholder: "Search members...") %>
    </div>
  </div>

  <%= form_with url: shg_members_path, method: :get, class: "filter-grid", data: { controller: "location-select" } do |form| %>
    <%= form.hidden_field :q, value: params[:q] if params[:q].present? %>
    <label><span>From Date</span><%= form.date_field :date_from, value: params[:date_from] %></label>
    <label><span>To Date</span><%= form.date_field :date_to, value: params[:date_to] %></label>
    <% if can_filter_member_state_district_crp? %>
      <label><span>State</span><%= form.collection_select :state_id, @states, :id, :name, { prompt: "All states", selected: params[:state_id] }, data: { location_select_target: "state", action: "location-select#stateChanged" } %></label>
      <label><span>District</span><%= form.select :district_id, options_for_select(district_filter_options(@districts), params[:district_id]), { prompt: "All districts" }, data: { location_select_target: "district", action: "location-select#districtChanged" } %></label>
    <% end %>
    <label><span>Block</span><%= form.select :block_id, options_for_select(block_filter_options(@blocks), params[:block_id]), { prompt: "All blocks" }, data: { location_select_target: "block", action: "location-select#blockChanged" } %></label>
    <label><span>Village</span><%= form.select :village_id, options_for_select(village_filter_options(@villages), params[:village_id]), { prompt: "All villages" }, data: { location_select_target: "village" } %></label>
    <label><span>SHG</span><%= form.collection_select :shg_id, @shgs, :id, :name, { prompt: "All SHG", selected: params[:shg_id] } %></label>
    <% if can_filter_member_state_district_crp? %>
      <label><span>CRP</span><%= form.select :crp_id, options_for_select(user_filter_options(@crps), params[:crp_id]), { prompt: "All CRP" }, data: { location_select_target: "crp" } %></label>
    <% end %>
    <div class="filter-actions">
      <%= link_to "Clear", shg_members_path, class: "secondary-link" %>
      <%= form.submit "Apply", class: "primary-button" %>
    </div>
  <% end %>

  <div class="searchable-table compact-search-results">
    <% if @members.blank? %><div class="table-empty-state">No matching members found.</div><% end %>
    <div class="table-wrap">
    <table>
      <thead><tr><% if can_bulk_delete_records? %><th class="select-column"><%= check_box_tag "select_all_members", "1", false, data: { bulk_select_all: true, bulk_select_form: "bulk-disable-members" }, aria: { label: "Select all members on this page" } %></th><% end %><th>Name</th><th>SHG</th><th>Loan No</th><th>Status</th><th>Monthly HH Income</th><th>Mobile</th><th>Action</th></tr></thead>
      <tbody>
        <% @members.each do |member| %>
          <tr>
            <% if can_bulk_delete_records? %><td><%= check_box_tag "ids[]", member.id, false, form: "bulk-disable-members", disabled: !member.active? %></td><% end %>
            <td><%= link_to member.name, member %></td>
            <td><%= member.shg.name %></td>
            <td><%= member.loan_no.presence || "-" %></td>
            <td><span class="status <%= member.active? ? "approved" : "rejected" %>"><%= member.active? ? "Active" : "Inactive" %></span></td>
            <td><%= member.monthly_income.present? ? number_to_currency(member.monthly_income, unit: "₹") : "-" %></td>
            <td><%= member.mobile %></td>
            <td><div class="action-row"><%= link_to "Details", member %><% if can_manage_shg_member?(member) %><%= link_to "Edit", edit_shg_member_path(member) %><% end %><% if can_bulk_delete_records? && member.active? %><%= button_to "Disable", disable_shg_member_path(member), method: :patch, class: "warning-link", form: { data: { turbo_confirm: "Disable this member?" } } %><% elsif !member.active? %><span class="muted-cell">Disabled</span><% end %></div></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    </div>
  </div>
  <%= pagination_controls("members") %>
</section>
